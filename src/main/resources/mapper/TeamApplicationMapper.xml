<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.workcompetitionplatform.mapper.TeamApplicationMapper">

    <!-- 结果映射 -->
    <resultMap id="TeamApplicationResultMap" type="com.example.workcompetitionplatform.entity.TeamApplication">
        <id column="id" property="id"/>
        <result column="team_id" property="teamId"/>
        <result column="applicant_id" property="applicantId"/>
        <result column="applicant_student_no" property="applicantStudentNo"/>
        <result column="applicant_email" property="applicantEmail"/>
        <result column="message" property="message"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="process_time" property="processTime"/>
        <result column="processor_id" property="processorId"/>
        <!-- 非数据库字段 -->
        <result column="applicant_name" property="applicantName"/>
        <result column="team_name" property="teamName"/>
    </resultMap>

    <!-- 根据团队ID查询待处理的申请 -->
    <select id="selectByTeamId" resultMap="TeamApplicationResultMap">
        SELECT * FROM team_application
        WHERE team_id = #{teamId}
        AND status = 'PENDING'
        ORDER BY create_time DESC
    </select>

    <!-- 根据团队ID查询待处理的申请（包含申请人姓名） -->
    <select id="selectApplicationsWithDetails" resultMap="TeamApplicationResultMap">
        SELECT
            ta.*,
            u.real_name AS applicant_name
        FROM team_application ta
        LEFT JOIN user u ON ta.applicant_id = u.id
        WHERE ta.team_id = #{teamId}
        AND ta.status = 'PENDING'
        ORDER BY ta.create_time DESC
    </select>

    <!-- 根据申请人ID查询申请列表（包含团队名称） -->
    <select id="selectMyApplicationsWithDetails" resultMap="TeamApplicationResultMap">
        SELECT
            ta.*,
            t.team_name
        FROM team_application ta
        LEFT JOIN team t ON ta.team_id = t.id
        WHERE ta.applicant_id = #{applicantId}
        ORDER BY ta.create_time DESC
    </select>

</mapper>