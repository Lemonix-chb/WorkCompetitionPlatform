<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.workcompetitionplatform.mapper.TeamInvitationMapper">

    <!-- 结果映射 -->
    <resultMap id="TeamInvitationResultMap" type="com.example.workcompetitionplatform.entity.TeamInvitation">
        <id column="id" property="id"/>
        <result column="team_id" property="teamId"/>
        <result column="inviter_id" property="inviterId"/>
        <result column="invitee_id" property="inviteeId"/>
        <result column="invitee_student_no" property="inviteeStudentNo"/>
        <result column="invitee_email" property="inviteeEmail"/>
        <result column="message" property="message"/>
        <result column="status" property="status"/>
        <result column="expire_time" property="expireTime"/>
        <result column="create_time" property="createTime"/>
        <result column="process_time" property="processTime"/>
        <!-- 非数据库字段 -->
        <result column="team_name" property="teamName"/>
        <result column="inviter_name" property="inviterName"/>
        <result column="inviter_no" property="inviterNo"/>
    </resultMap>

    <!-- 根据被邀请人ID查询待处理的邀请 -->
    <select id="selectByInviteeId" resultMap="TeamInvitationResultMap">
        SELECT * FROM team_invitation
        WHERE invitee_id = #{inviteeId}
        AND status = 'PENDING'
        AND expire_time > NOW()
        ORDER BY create_time DESC
    </select>

    <!-- 根据被邀请用户ID查询邀请列表（包含团队名和邀请人姓名） -->
    <select id="selectInvitationsWithDetails" resultMap="TeamInvitationResultMap">
        SELECT
            ti.*,
            t.team_name,
            u.real_name AS inviter_name,
            u.student_no AS inviter_no,
            u.teacher_no AS inviter_no
        FROM team_invitation ti
        LEFT JOIN team t ON ti.team_id = t.id
        LEFT JOIN user u ON ti.inviter_id = u.id
        WHERE ti.invitee_id = #{invitedUserId}
        ORDER BY ti.create_time DESC
    </select>

</mapper>