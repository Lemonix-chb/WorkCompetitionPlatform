<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.workcompetitionplatform.mapper.UserRoleMapper">

    <!-- 根据用户ID查询所有角色关联 -->
    <select id="selectByUserId" resultType="com.example.workcompetitionplatform.entity.UserRole">
        SELECT *
        FROM user_role
        WHERE user_id = #{userId}
    </select>

    <!-- 根据角色ID查询所有用户关联 -->
    <select id="selectByRoleId" resultType="com.example.workcompetitionplatform.entity.UserRole">
        SELECT *
        FROM user_role
        WHERE role_id = #{roleId}
    </select>

    <!-- 删除用户的所有角色关联 -->
    <delete id="deleteByUserId">
        DELETE FROM user_role
        WHERE user_id = #{userId}
    </delete>

    <!-- 删除角色的所有用户关联 -->
    <delete id="deleteByRoleId">
        DELETE FROM user_role
        WHERE role_id = #{roleId}
    </delete>

</mapper>